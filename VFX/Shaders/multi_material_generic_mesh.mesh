#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_nonuniform_qualifier : require

#ifndef gl_MaxMeshOutputVerticesEXT
    #define gl_MaxMeshOutputVerticesEXT 256
#endif
#ifndef gl_MaxMeshOutputPrimitivesEXT
    #define gl_MaxMeshOutputPrimitivesEXT 128
#endif

layout(local_size_x = 1) in;

layout(max_vertices = 256, max_primitives = 128) out;
layout(triangles) out;

// ------------------------------------------------------------
// Data Structures
// ------------------------------------------------------------
struct Vertex {
    vec3 position;
    vec3 normal;
    vec2 uv;
};

struct MeshInfo {
    uint vertexOffset;
    uint indexOffset;
    uint indexCount;
    uint modelIndex;
    uint materialIndex;  
    float depth;
};

struct Material {
    vec4 albedo;
    uint albedoIndex;
    uint maskTextureIndex;
    uint pad1;
    uint pad2;
};

// ------------------------------------------------------------
// Buffers
// ------------------------------------------------------------
layout(std430, binding = 0) readonly buffer VertexBuffer {
    Vertex vertices[];
};
layout(std430, binding = 1) readonly buffer IndexBuffer {
    uint indices[];
};

layout(std140, binding = 2) uniform PerFrame {
    mat4 view;
    mat4 proj;
} ubo;

layout(std140, binding = 3) uniform MeshTransforms {
    mat4 models[1024];
};

layout(std430, binding = 4) readonly buffer MeshInfos {
    MeshInfo meshes[];
};

layout(std140, binding = 5) uniform Materials {
    Material materials[32];
};

// ------------------------------------------------------------
// FS output
// ------------------------------------------------------------
layout(location = 0) out vec3 vNormal[];
layout(location = 1) out vec2 vUV[];
layout(location = 2) out vec4 vAlbedo[];
layout(location = 3) out float vMetallic[];
layout(location = 4) out float vRoughness[];
layout(location = 5) out flat uint vTextureIndex[];
layout(location = 7) out flat uint vMaskTextureIndex[];

// ------------------------------------------------------------
// Main mesh shader
// ------------------------------------------------------------
void main()
{
    uint meshIndex = gl_WorkGroupID.x;
    MeshInfo mesh = meshes[meshIndex];

    mat4 model = models[mesh.modelIndex];
    mat4 MVP   = ubo.proj * ubo.view * model;
    mat3 normalMat = mat3(model);

    // Fetch material
    Material material = materials[mesh.materialIndex];

    uint triCount = mesh.indexCount / 3;
    uint vertCount = triCount * 3;

    triCount  = min(triCount, gl_MaxMeshOutputPrimitivesEXT);
    vertCount = min(vertCount, gl_MaxMeshOutputVerticesEXT);

    SetMeshOutputsEXT(vertCount, triCount);

    for (uint i = 0; i < triCount; ++i) {

        uint idx0 = indices[mesh.indexOffset + i * 3 + 0] + mesh.vertexOffset;
        uint idx1 = indices[mesh.indexOffset + i * 3 + 1] + mesh.vertexOffset;
        uint idx2 = indices[mesh.indexOffset + i * 3 + 2] + mesh.vertexOffset;

        Vertex v0 = vertices[idx0];
        Vertex v1 = vertices[idx1];
        Vertex v2 = vertices[idx2];

        uint base = i * 3;

        vec3 position0 = v0.position;
        vec3 position1 = v1.position;
        vec3 position2 = v2.position;

        position0.z -= mesh.depth;
        position1.z -= mesh.depth;
        position2.z -= mesh.depth;

        vec4 position00 = MVP * vec4(position0, 1.0);
        vec4 position10 = MVP * vec4(position1, 1.0);
        vec4 position20 = MVP * vec4(position2, 1.0);

        gl_MeshVerticesEXT[base + 0].gl_Position = position00;
        gl_MeshVerticesEXT[base + 1].gl_Position = position10;
        gl_MeshVerticesEXT[base + 2].gl_Position = position20;

        vNormal [base + 0] = normalize(normalMat * v0.normal);
        vNormal [base + 1] = normalize(normalMat * v1.normal);
        vNormal [base + 2] = normalize(normalMat * v2.normal);

        vUV     [base + 0] = v0.uv;
        vUV     [base + 1] = v1.uv;
        vUV     [base + 2] = v2.uv;

        // Pass material parameters per vertex
        vAlbedo[base + 0] = material.albedo;
        vAlbedo[base + 1] = material.albedo;
        vAlbedo[base + 2] = material.albedo;

        vMetallic [base + 0] = 0; //material.metallic;
        vMetallic [base + 1] = 0; //material.metallic;
        vMetallic [base + 2] = 0; //material.metallic;

        vRoughness[base + 0] = 0; //material.roughness;
        vRoughness[base + 1] = 0; //material.roughness;
        vRoughness[base + 2] = 0; //material.roughness;

        vTextureIndex[base + 0] = material.albedoIndex;
        vTextureIndex[base + 1] = material.albedoIndex;
        vTextureIndex[base + 2] = material.albedoIndex;

        vMaskTextureIndex[base + 0] = material.maskTextureIndex;
        vMaskTextureIndex[base + 1] = material.maskTextureIndex;
        vMaskTextureIndex[base + 2] = material.maskTextureIndex;

        gl_PrimitiveTriangleIndicesEXT[i] = uvec3(base + 0, base + 1, base + 2);

    }
}
