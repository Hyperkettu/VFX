#version 460
#extension GL_EXT_mesh_shader : require

layout(local_size_x = 32) in;
layout(triangles, max_vertices = 128, max_primitives = 64) out;

struct EulerParticle {
    vec3 position;
    float pad0;      
    vec3 velocity;
    float pad1;
    vec4 color;
    float life;
    float maxLifetime;
    vec2 pad2;       
};

layout(std430, binding = 0) readonly buffer ParticleSSBOIn {
    EulerParticle particlesIn[];
};

layout(std140, binding = 1) uniform PerFrame {
    mat4 view;
    mat4 proj;
} ubo;

layout(std140, binding = 2) uniform MeshTransforms {
    mat4 models[1024];
} model;

// Locations must be specified for fragment shader input
layout(location = 0) out vec2 vUV[];
layout(location = 1) out vec4 vColor[];

void main()
{
    if (gl_LocalInvocationID.x == 0) {
        SetMeshOutputsEXT(128, 64);
    }

    uint particleIndex = gl_GlobalInvocationID.x;
    uint localID = gl_LocalInvocationID.x;
    
    EulerParticle p = particlesIn[particleIndex];

    if (p.life <= 0.0) {
        
    }

    mat4 world = model.models[0];

    vec4 viewPos = ubo.view * world * vec4(p.position, 1.0);
    float size = 0.1;
    
    vec2 offsets[4] = vec2[](
        vec2(-size, -size), vec2(size, -size), 
        vec2(-size,  size), vec2(size,  size)
    );
    vec2 uvs[4] = vec2[](
        vec2(0,0), vec2(1,0), 
        vec2(0,1), vec2(1,1)
    );

    uint vBase = localID * 4;
    for (uint v = 0; v < 4; v++) {
        uint vIdx = vBase + v;
        vec4 pos = viewPos;
        pos.xy += offsets[v];
        
        gl_MeshVerticesEXT[vIdx].gl_Position = ubo.proj * pos;
        vUV[vIdx] = uvs[v];
        vColor[vIdx] = p.color;
    }

    uint pBase = localID * 2;
    gl_PrimitiveTriangleIndicesEXT[pBase + 0] = uvec3(vBase + 0, vBase + 2, vBase + 1);
    gl_PrimitiveTriangleIndicesEXT[pBase + 1] = uvec3(vBase + 2, vBase + 3, vBase + 1);
}